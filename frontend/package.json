{
  "name": "anime-recommender-frontend",
  "version": "1.0.0",
  "description": "Frontend para sistema de recomendación de anime",
  "main": "index.html",
  "scripts": {
    "dev": "live-server --port=3000 --open=/index.html --ignore=node_modules --no-css-inject",
    "dev-simple": "python -m http.server 3000",
    "dev-node": "http-server -p 3000 -c-1 -o",
    "build": "echo 'No build process needed for vanilla HTML/CSS/JS'",
    "start": "serve -s . -l 3000"
  },
  "devDependencies": {
    "live-server": "^1.2.2",
    "http-server": "^14.1.1"
  },
  "dependencies": {
    "serve": "^14.2.1"
  },
  "keywords": [
    "anime",
    "recommendation",
    "frontend",
    "javascript"
  ],
  "author": "Tu nombre",
  "license": "MIT"
}